{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p .claude/logs && printf '%s\\t%s\\t%s\\n' \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\" \"${CLAUDE_TOOL_NAME:-unknown}\" \"${CLAUDE_TOOL_INPUT_FILE_PATH:-unknown}\" >> .claude/logs/edits.log"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "create_ticket|notify_oncall",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/pretooluse_writes.py"
          }
        ]
      }
    ]
  }
}
